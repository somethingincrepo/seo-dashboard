# Crawler service env. In production, set these as Fly secrets:
#   fly secrets set SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=... CRAWLER_SERVICE_TOKEN=... VERCEL_BASE_URL=...

# Shared with the dashboard — same value on both sides.
CRAWLER_SERVICE_TOKEN=

# Service-role Supabase credentials. The crawler writes pages and updates audit_runs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The dashboard's public origin. The crawler POSTs to {VERCEL_BASE_URL}/api/audit/diagnose
# when crawling completes, which kicks off the rules engine.
VERCEL_BASE_URL=https://your-dashboard.vercel.app

PORT=8080
