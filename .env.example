# Existing dashboard env (already wired via .env.local) -----------------------
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ADMIN_PASSWORD=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# ANTHROPIC_API_KEY=

# Audit engine (new, added in Phase 1) ---------------------------------------

# Base URL of the Fly crawler service. The dashboard POSTs /crawl here when an
# audit is triggered. Trailing slash stripped automatically.
CRAWLER_SERVICE_URL=https://something-audit-crawler.fly.dev

# Shared bearer token. Required on every /crawl call from the dashboard, and
# the crawler echoes it back when calling /api/audit/diagnose. Generate with:
#   openssl rand -hex 32
# Set the SAME value as a Fly secret on the crawler:
#   cd services/crawler && fly secrets set CRAWLER_SERVICE_TOKEN=<value>
CRAWLER_SERVICE_TOKEN=

# Connections subsystem (lib/connections) ------------------------------------
# All client CMS credentials get encrypted at rest in Supabase using AES-256-GCM.
# Generate the key with:
#   openssl rand -base64 32
# Rotate by re-encrypting all rows; never reuse old keys.
CONNECTION_ENCRYPTION_KEY=

# Public URL of this app. Used to build OAuth redirect URIs.
# Example: https://seo-dashboard-teal-phi.vercel.app
APP_URL=

# Shopify OAuth (register at partners.shopify.com → create Custom App)
# Redirect URI to whitelist on Shopify: {APP_URL}/api/connections/shopify/callback
# Required scopes: write_content,read_content,write_redirects,read_redirects,write_themes,read_themes
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# HubSpot OAuth (register at developers.hubspot.com → create Public App)
# Redirect URI to whitelist on HubSpot: {APP_URL}/api/connections/hubspot/callback
# Required scopes: content forms oauth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Webflow OAuth (register at developers.webflow.com → create app)
# Redirect URI to whitelist on Webflow: {APP_URL}/api/connections/webflow/callback
# Required scopes: sites:read cms:read cms:write pages:read pages:write
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=
