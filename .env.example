# Existing dashboard env (already wired via .env.local) -----------------------
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ADMIN_PASSWORD=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# ANTHROPIC_API_KEY=

# Audit engine (new, added in Phase 1) ---------------------------------------

# Base URL of the Fly crawler service. The dashboard POSTs /crawl here when an
# audit is triggered. Trailing slash stripped automatically.
CRAWLER_SERVICE_URL=https://something-audit-crawler.fly.dev

# Shared bearer token. Required on every /crawl call from the dashboard, and
# the crawler echoes it back when calling /api/audit/diagnose. Generate with:
#   openssl rand -hex 32
# Set the SAME value as a Fly secret on the crawler:
#   cd services/crawler && fly secrets set CRAWLER_SERVICE_TOKEN=<value>
CRAWLER_SERVICE_TOKEN=
